POSTGRES_DB=peilv
POSTGRES_PASSWORD=replace-with-generated-password
AUTHENTICATOR_PASSWORD=replace-with-generated-password
JWT_SECRET=replace-with-at-least-32-random-characters
ANON_KEY=replace-with-generated-jwt
SERVICE_ROLE_KEY=replace-with-generated-jwt
LOCAL_API_PORT=54321
PEILV_LOCAL_DATA_DIR=../../.local-data
# Production internal API authentication is supplied by systemd LoadCredential,
# not by this environment file. Local development may explicitly set:
# INTERNAL_API_SECRET_FILE=/absolute/path/to/a/private/credential
# Explicitly approve additional exact outbound domains (or *.example.invalid subdomains).
# ADMIN_OUTBOUND_ALLOWED_HOSTS=llm.example.invalid,search.example.invalid
# HTTPS defaults to 443. List non-standard ports only after administrator review.
# ADMIN_OUTBOUND_ALLOWED_PORTS=8443
