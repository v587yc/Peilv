#!/usr/bin/env bash
set -Eeuo pipefail

caller="${SUDO_USER:-}"
command_name="${1:-}"

case "$caller:$command_name:$#" in
  peilv-audit:preflight:9)
    exec /usr/local/libexec/peilv/production-preflight.sh "$2" "$3" "$4" "$5" "$6" "$7" "$8" "$9"
    ;;
  peilv-deploy:deploy:5)
    exec /usr/local/libexec/peilv/deploy-production.sh "$2" "$3" "$4" "$5"
    ;;
  peilv-rollback:rollback:5)
    exec /usr/local/libexec/peilv/rollback-production.sh "$2" "$3" "$4" "$5"
    ;;
  *)
    printf 'Command is not permitted\n' >&2
    exit 126
    ;;
esac
